# ============================================================
# DevChrono JSONLab API - Environment Variables
# Copy to .env and configure
# ============================================================

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# CORS - comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:4001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=0
RATE_LIMIT_MAX_REQUESTS=0
RATE_LIMIT_JSON_MAX=0
RATE_LIMIT_AUTH_WINDOW_MS=0
RATE_LIMIT_AUTH_MAX=0

# Request body limits
BODY_LIMIT_DEFAULT=0mb
BODY_LIMIT_JSON=0mb

# Logging
LOG_LEVEL=info

# Optional Redis (for distributed rate limiting)
# REDIS_URL=redis://localhost:6379

# Optional PostgreSQL (for user accounts)
# DATABASE_URL=postgresql://user:password@localhost:5432/devchrono
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=devchrono
# SSL_DB_ENABLED=false
# SSL_DB_REJECT_UNAUTHORIZED=false

# API Version
API_VERSION=v1

# ============================================================
# Auth / JWT
# ============================================================
JWT_SECRET=change_me_generate_a_long_random_string
JWT_REFRESH_SECRET=change_me_generate_a_different_long_random_string
# Isolated secret for password-reset tokens (falls back to JWT_SECRET if unset)
JWT_RESET_SECRET=change_me_generate_another_long_random_string
# 32-byte key (64 hex chars) used to encrypt JWT claims before signing, so the
# token payload isn't readable even though it's a normal verifiable JWT.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_PAYLOAD_ENCRYPTION_KEY=change_me_64_hex_chars

ACCESS_TOKEN_TTL=0m
ACCESS_TOKEN_TTL_SECONDS=0
REFRESH_TOKEN_TTL=0d
REFRESH_TOKEN_TTL_DAYS=0
PASSWORD_RESET_TOKEN_TTL=0m

# ============================================================
# Password hashing
# ============================================================
BCRYPT_SALT_ROUNDS=00
PASSWORD_PEPPER=change_me_64_hex_chars
# Server-only secret mixed into every password hash (HMAC), in addition to
# bcrypt's own per-hash random salt. Never store this alongside the database.

DEV_SEED_EMAIL=change_me_a_real_developer_email
DEV_SEED_PASSWORD=change_me_a_real_password

# ============================================================
# AWS S3 (Storage Vault)
# ============================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ============================================================
# Storage Vault tunables
# ============================================================
DEFAULT_STORAGE_QUOTA_BYTES=1099511627776
SHARE_LINK_TTL_SECONDS=600
DOWNLOAD_LINK_TTL_SECONDS=900
EVENT_CLUSTER_GAP_MINUTES=240
UPLOAD_SECURITY_SCAN_BYTES=4096

# ============================================================
# In-app file preview
# ============================================================
PREVIEW_TEXT_MAX_BYTES=2097152
PREVIEW_URL_TTL_SECONDS=300

# ============================================================
# Google OAuth ("Continue with Google")
# ============================================================
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console >
# APIs & Services > Credentials, and register GOOGLE_OAUTH_REDIRECT_URI below
# exactly as an "Authorized redirect URI" on that client.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
# (post-Google-login redirect target reuses CORS_ORIGIN above, no separate var needed)

# ============================================================
# Transactional email (nodemailer)
# ============================================================
# Fire-and-forget account-lifecycle emails — a Gmail account with an "App Password"
# (not your normal password; generate one at myaccount.google.com/apppasswords)
# works fine for low volume; swap for a real transactional provider (SES, Postmark,
# SendGrid) before any real send volume.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM_NAME=DevKits Vault
