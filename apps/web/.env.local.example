# DevChrono JSONLab Web - Environment Variables
# Copy to .env.local

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=DevChrono JSONLab
NEXT_PUBLIC_APP_URL=http://localhost:4001

# Support / contribution contacts — rendered client-side (Support page + floating
# widget), so these are public-facing by nature, not secrets. Kept out of source
# so they can be swapped per-deployment without touching code.
NEXT_PUBLIC_PAYPAL_LINK=https://paypal.me/YOUR_PAYPAL_HANDLE
NEXT_PUBLIC_UPI_ID=your-upi-id@bank
NEXT_PUBLIC_WHATSAPP_NUMBER=911234567890
NEXT_PUBLIC_SUPPORT_EMAIL=support@devchronojsonlab.example

# Server-only secret — read by the /api/weather route, never exposed to the
# browser. Do NOT prefix with NEXT_PUBLIC_.
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
