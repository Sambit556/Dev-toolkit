{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": ["checkly.config.ts", "__checks__/**/*.ts"],
  "exclude": ["node_modules", "apps", "packages"]
}
