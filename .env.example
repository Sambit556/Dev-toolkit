# ============================================================
# DevChrono JSONLab - Root Environment Variables
# Copy to .env and fill in values
# ============================================================

# Node environment
NODE_ENV=development

# API Service
API_PORT=3001
API_HOST=0.0.0.0

# Web Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Redis (optional - for rate limiting in multi-instance deployments)
REDIS_URL=redis://localhost:6379

# PostgreSQL (optional - for user accounts)
DATABASE_URL=postgresql://devchrono:password@localhost:5432/devchrono_db

# Logging
LOG_LEVEL=info

# Security
CORS_ORIGIN=http://localhost:3000
